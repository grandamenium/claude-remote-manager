.env
agents/*/.env
agents/*/local/
agents/*/telegram-images/
*.log
.DS_Store

# Keep agent-template config (needed for distribution)
!agents/agent-template/.claude/
!agents/agent-template/.claude/settings.json

# Exclude live agent configs (contain user-specific data)
agents/*/memory/
agents/jimbo/

# MCP configs (contain bot tokens and user-specific paths)
agents/*/.claude.json
agents/*/.claude/

# Runtime and tool state
.serena/
state/
agents/*/.playwright-mcp/

# Screenshots and client data (user-specific)
agents/*/*.png
agents/*/telegram-docs/
agents/*/ocg_*.txt
