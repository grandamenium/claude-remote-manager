{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash ../../bus/hook-planmode-telegram.sh",
            "timeout": 1860
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ../../bus/hook-permission-telegram.sh",
            "timeout": 1860
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash ../../bus/hook-ask-telegram.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ../../scripts/crash-alert.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
